[Unit]
Description=Bot Admin Dashboard
Wants=redis-server.service
After=network.target redis-server.service

[Service]
Type=simple
WorkingDirectory=/opt/bot
EnvironmentFile=/opt/bot/.env
User=bot
Group=bot
UMask=0027
NoNewPrivileges=true
PrivateTmp=true
ProtectHome=true
ProtectSystem=full
ReadWritePaths=/opt/bot
ExecStart=/opt/bot/venv/bin/uvicorn admin_dashboard:app --host 127.0.0.1 --port 8080
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
